@page
@model CreateModel
@{
    ViewData["Title"] = "Nowe Rozliczenie";
}

<div class="card shadow-sm p-4">
    <h3>Dane osobowe</h3>
    <form method="post">
        <div class="row mb-3">
            <div class="col">
                <label>Imię</label>
                <input asp-for="Rozliczenie.Imie" class="form-control" />
            </div>
            <div class="col">
                <label>Nazwisko</label>
                <input asp-for="Rozliczenie.Nazwisko" class="form-control" />
            </div>
        </div>

        <div class="mb-3">
            <label>PESEL</label>
            <input asp-for="Rozliczenie.Pesel" class="form-control" />
        </div>

        <hr />
        <h3>Finanse</h3>
        <div class="row">
            <div class="col-md-4">
                <label>Przychód</label>
                <input asp-for="Przychod" class="form-control" />
            </div>
            <div class="col-md-4">
                <label>Koszty</label>
                <input asp-for="Koszty" class="form-control" />
            </div>
            <div class="col-md-4 d-flex align-items-end">
                <button type="submit" asp-page-handler="Calculate" class="btn btn-primary w-100">
                    Przelicz
                </button>
            </div>
        </div>

        <div class="mt-4 p-3 bg-light border rounded">
            <p><strong>Podatek należny:</strong> @Model.PodatekNalezy.ToString("N2") zł</p>
        </div>

        <div class="mt-4 text-end">
            <button type="submit" asp-page-handler="Save" class="btn btn-success px-5">
                Zapisz
            </button>
            <a asp-page="/Index" class="btn btn-secondary">Powrót</a>
        </div>
    </form>
</div>