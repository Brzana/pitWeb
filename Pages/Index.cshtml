@page
@model IndexModel
@{
    ViewData["Title"] = "Twój Asystent PIT-38";
}

<div class="row g-4 mb-5">
    <div class="col-md-6">
        <div class="card shadow-sm p-4 h-100">
            <div class="text-center mb-3">
                <svg xmlns="http://www.w3.org/2000/svg" width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="#0077cc" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <line x1="12" y1="5" x2="12" y2="19"></line>
                    <line x1="5" y1="12" x2="19" y2="12"></line>
                </svg>
            </div>
            <h3 class="text-center">Nowe rozliczenie</h3>
            <p class="text-center text-muted mb-4">Utwórz nowy formularz PIT-38</p>
            <div class="mt-auto">
                <a asp-page="/Form/Create" class="btn btn-primary w-100">ROZPOCZNIJ NOWE</a>
            </div>
        </div>
    </div>

    <div class="col-md-6">
        <div class="card shadow-sm p-4 h-100">
            <div class="text-center mb-3">
                <svg xmlns="http://www.w3.org/2000/svg" width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="#28a745" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M9 11l3 3L22 4"></path>
                    <path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"></path>
                </svg>
            </div>
            <h3 class="text-center">Historia rozliczeń</h3>
            <p class="text-center text-muted mb-4">Wyświetl listę zapisanych formularzy</p>
            <div class="mt-auto">
                <a asp-page="/History" class="btn btn-success w-100">PRZEGLĄDAJ ZAPISANE</a>
            </div>
        </div>
    </div>
</div>

<div class="card shadow-sm p-4">
    <h4 class="mb-4">Ostatnie dokumenty</h4>
    
    @if (Model.RecentDocuments != null && Model.RecentDocuments.Count > 0)
    {
        <div class="table-responsive">
            <table class="table table-striped table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Data</th>
                        <th>Imię i Nazwisko</th>
                        <th>PESEL</th>
                        <th>Podatek należny</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var doc in Model.RecentDocuments)
                    {
                        <tr>
                            <td>@doc.DataZapisu.ToString("dd.MM.yyyy HH:mm")</td>
                            <td>@doc.ImieNazwisko</td>
                            <td>@doc.Pesel</td>
                            <td>@doc.PodatekNalezy.ToString("N2") zł</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <p class="text-muted">Brak dokumentów</p>
    }
</div>
