@page
@model HistoryModel
@{
    ViewData["Title"] = "Historia rozliczeń";
}

<div class="card shadow-sm p-4">
    <h3 class="mb-4">Historia rozliczeń</h3>
    
    @if (Model.AllDocuments != null && Model.AllDocuments.Count > 0)
    {
        <div class="table-responsive">
            <table class="table table-striped table-hover">
                <thead class="table-light">
                    <tr>
                        <th>Data zapisu</th>
                        <th>Rok podatkowy</th>
                        <th>Imię i Nazwisko</th>
                        <th>PESEL</th>
                        <th>Podatek należny</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var doc in Model.AllDocuments)
                    {
                        <tr>
                            <td>@doc.DataZapisu.ToString("dd.MM.yyyy HH:mm")</td>
                            <td>@doc.RokPodatkowy</td>
                            <td>@doc.ImieNazwisko</td>
                            <td>@doc.Pesel</td>
                            <td>@doc.PodatekNalezy.ToString("N2") zł</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <p class="text-muted">Brak zapisanych rozliczeń</p>
    }

    <div class="mt-4 text-start">
        <a asp-page="/Index" class="btn btn-secondary">Powrót</a>
    </div>
</div>
